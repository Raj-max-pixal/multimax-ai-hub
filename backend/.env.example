# ============================================================
# Multimax AI Hub - Backend Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# ============================================================

# --- Application ---
APP_NAME=Multimax AI Hub
APP_VERSION=0.4.0
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-secret-key
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=multimax
POSTGRES_USER=multimax
POSTGRES_PASSWORD=multimax_dev
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- ChromaDB (Vector Database) ---
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_URL=http://${CHROMADB_HOST}:${CHROMADB_PORT}

# --- Ollama (Local AI Models) ---
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_URL=http://${OLLAMA_HOST}:${OLLAMA_PORT}
OLLAMA_DEFAULT_MODEL=phi3:latest

# --- Optional Cloud AI Providers (user can add their own API keys) ---
# OPENAI_API_KEY=
# CLAUDE_API_KEY=
# GEMINI_API_KEY=

# --- Storage ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
STORAGE_BACKEND=local  # local | supabase | s3

# --- Supabase (Optional - Free Tier) ---
# SUPABASE_URL=
# SUPABASE_KEY=
# SUPABASE_SERVICE_KEY=

# --- Authentication ---
AUTH_SECRET_KEY=change-me-to-another-random-secret
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MINUTES=15

# --- Event Bus ---
EVENT_BUS_BACKEND=memory  # memory | postgresql
EVENT_BUS_MAX_RETRIES=3
EVENT_BUS_RETRY_DELAY_SECONDS=5
EVENT_BUS_DEAD_LETTER_MAX=1000

# --- API ---
API_RATE_LIMIT_PER_MINUTE=60
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001

# --- Logging ---
LOG_FORMAT=json  # json | text
LOG_FILE=./logs/app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5